# ── Cloudflare Turnstile ─────────────────────────────────────────────
# Public site key — exposed to the browser. Vite requires the VITE_ prefix.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Secret key — server-side only, used by /api/contact to verify tokens.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Resend ───────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender (must be on a domain you've verified in Resend).
CONTACT_FROM="Afrikatek Website <website@afrikatek.co.za>"
# Where contact-form submissions are delivered.
CONTACT_TO=hello@afrikatek.co.za
